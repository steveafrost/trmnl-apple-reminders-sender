{% template reminder_legacy_item %}
{% assign title = item.name | default: item.title | default: item.n %}
{% assign date = item.deadline | default: item.date | default: item.d %}
{% assign priority = item.priority | default: item.p %}
{% assign flagged = item.flagged | default: item.f %}
{% assign list = item.list | default: item.list_name | default: item.l %}
{% assign notes = item.notes | default: item.description | default: item.o %}

<div class="item w--full">
  <div class="meta"></div>
  <div class="content w--full">
    <span class="title title--small">{% if flagged %}! {% endif %}{{ title | escape }}</span>
    {% if show_details %}
      {% if date and date != "" %}
        <span class="description">{{ date | escape }}</span>
      {% endif %}
      {% if priority and priority != "" and priority != "None" %}
        <span class="description">{{ priority | escape }}</span>
      {% endif %}
      {% if list and list != "" %}
        <span class="description">{{ list | escape }}</span>
      {% endif %}
      {% if notes and notes != "" %}
        <span class="description" data-clamp="2">{{ notes | escape }}</span>
      {% endif %}
    {% endif %}
  </div>
</div>
{% endtemplate %}

{% template reminder_v2_item %}
{% assign title = item.title | default: item.name | default: item.n %}
{% assign date = item.date | default: item.deadline | default: item.d %}
{% assign notes = item.description | default: item.notes | default: item.o %}
{% assign subtask_count = item.num_tasks | default: 0 %}

<div class="item w--full">
  <div class="meta"></div>
  <div class="content w--full">
    <span class="title title--small">{% if item.idx %}{{ item.idx }}. {% endif %}{{ title | escape }}</span>
    {% if show_details %}
      {% if date and date != "" %}
        <span class="description">{{ date | escape }}</span>
      {% endif %}
      {% if subtask_count > 0 %}
        <span class="description">{{ subtask_count }} subtasks</span>
      {% endif %}
      {% if notes and notes != "" %}
        <span class="description" data-clamp="2">{{ notes | escape }}</span>
      {% endif %}
    {% endif %}
  </div>
</div>
{% endtemplate %}

{% template title_bar %}
<div class="title_bar">
  <span class="title">Apple Reminders</span>
  {% if list_name and data_time %}
    <span class="instance">{{ list_name | escape }} @ {{ data_time | escape }}</span>
  {% elsif trmnl.plugin_settings.custom_fields_values.expected_format %}
    <span class="instance">{{ trmnl.plugin_settings.custom_fields_values.expected_format | escape }}</span>
  {% endif %}
</div>
{% endtemplate %}
